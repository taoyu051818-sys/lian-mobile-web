{
  "name": "lian-mobile-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run serve:dist",
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "node scripts/validate-project-structure.js && node scripts/check-encoding-contamination.js",
    "check:encoding": "node scripts/check-encoding-contamination.js",
    "serve:dist": "node scripts/serve-frontend-static-rehearsal.js",
    "smell:guard": "node scripts/guard-runtime-contract.js && node scripts/guard-vue-migration.js",
    "test": "node scripts/smoke-frontend.js http://127.0.0.1:4300",
    "test:runtime": "node scripts/test-runtime-contract.js",
    "start:frontend-static": "npm run serve:dist"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
