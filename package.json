{
  "name": "lian-mobile-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/serve-frontend-runtimes.js",
    "dev": "vite --host 0.0.0.0",
    "dev:vue-canary": "vite --host 0.0.0.0 --port 4301 --strictPort",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "preview:vue-canary": "vite preview --host 0.0.0.0 --port 4301 --strictPort",
    "check": "node scripts/validate-project-structure.js && node scripts/check-encoding-contamination.js",
    "check:encoding": "node scripts/check-encoding-contamination.js",
    "audit:v-html": "node scripts/audit-v-html-usage.js",
    "ops:guard": "node scripts/guard-runtime-inventory.js",
    "serve:legacy": "node scripts/serve-frontend-static-rehearsal.js",
    "test": "node scripts/smoke-frontend.js http://127.0.0.1:4300",
    "test:vue-canary": "node scripts/smoke-frontend.js http://127.0.0.1:4301",
    "verify": "npm run check && npm run ops:guard && npm run build",
    "start:frontend-static": "node scripts/serve-frontend-runtimes.js"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
